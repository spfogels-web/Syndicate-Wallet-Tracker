# ===== App =====
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
PUBLIC_URL=https://your-app.up.railway.app

# ===== Database =====
DATABASE_URL=postgresql://user:password@host:5432/syndicate

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
# Optional: default chat to send alerts to if a project has no chatId set
TELEGRAM_DEFAULT_CHAT_ID=
# Comma-separated list of Telegram user IDs that bootstrap admin access
TELEGRAM_BOOTSTRAP_ADMINS=

# ===== Solana / Helius =====
HELIUS_API_KEY=
# Used to verify incoming Helius webhook payloads
HELIUS_WEBHOOK_AUTH_HEADER=

# ===== Ethereum + Base / Alchemy =====
ALCHEMY_API_KEY=
# Signing key for Alchemy webhook verification (per-webhook signing key)
ALCHEMY_WEBHOOK_SIGNING_KEY=

# ===== Etherscan family (Etherscan v2 covers ETH + Base) =====
ETHERSCAN_API_KEY=
